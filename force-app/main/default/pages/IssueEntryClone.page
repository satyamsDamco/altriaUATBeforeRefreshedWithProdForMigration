            function disabledFields(){
                var val = document.getElementById('pg:frm1:IssEntryBlock:IqosInfo:serialNumber').value;
                if(val != null && val != ''){
                    document.getElementById('pg:frm1:IssEntryBlock:IssDetail:tcSerialNum').disabled = true;
                    document.getElementById('pg:frm1:IssEntryBlock:IssDetail:tcSerialNum').value = '';
                    
                    document.getElementById('pg:frm1:IssEntryBlock:IssDetail:traceCode').disabled = true;
                    document.getElementById('pg:frm1:IssEntryBlock:IssDetail:traceCode').value = '';
                }
                else{
                    document.getElementById('pg:frm1:IssEntryBlock:IssDetail:tcSerialNum').disabled = false;
                    document.getElementById('pg:frm1:IssEntryBlock:IssDetail:traceCode').disabled = false;
                }
            }
