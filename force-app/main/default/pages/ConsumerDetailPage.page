    </div>
    <apex:pageBlock id="ChatHistId" title="Chat History">
        <apex:pageBlockTable value="{!ChatHistory}" var="c" rendered="{!NOT(ISNULL(ChatHistory))}" rows="20">
            <apex:column value="{!c.Chat_ID__c}"/>
            <apex:column value="{!c.CreatedDate}"/>
            <apex:column value="{!c.CreatedBy.Name}" headerValue="Created By"/>
            <apex:column value="{!c.Issue_ID__c}"/>
            <apex:column value="{!c.WaitTime}"/>
            <apex:column value="{!c.StartTime}"/>
            <apex:column value="{!c.EndTime}"/>
            <apex:column value="{!c.LastModifiedDate}"/>
            <apex:column value="{!c.LastModifiedBy.Name}" headerValue="Last Modified By"/>
        </apex:pageBlockTable>
        <apex:outputLabel value="No records to display" rendered="{!(ISNULL(ChatHistory))}"/>
    </apex:pageBlock>
    
</apex:page>