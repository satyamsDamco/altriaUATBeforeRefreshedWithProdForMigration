              <apex:outputField value="{!contact.State__c}" /> 
               <apex:outputField value="{!contact.Country__c}" id="country1" />
           </apex:pageBlockSection>
            
           <apex:pageBlockSection title="Contact Information">
              <apex:outputField value="{!contact.Phone}" rendered="{!contact.CustomerType__c   ==$Label.Wholesaler || contact.CustomerType__c ==$Label.Retailer}"/>
