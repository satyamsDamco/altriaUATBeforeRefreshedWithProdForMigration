<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Store_Comments_Commas</fullName>
    <active>true</active>
    <errorConditionFormula>CONTAINS(     Store_Comment__c     , &quot;,&quot;)</errorConditionFormula>
    <errorDisplayField>Store_Comment__c</errorDisplayField>
    <errorMessage>Field cannot contain commas</errorMessage>
</ValidationRule>
