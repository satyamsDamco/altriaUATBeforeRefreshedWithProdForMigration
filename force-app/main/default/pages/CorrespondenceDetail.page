<apex:page standardController="Correspondence_Fulfilment__c">
 <apex:includeScript value="/support/console/37.0/integration.js" /> 
    <apex:sectionHeader title="Correspondence/Fulfilment Detail" subtitle="{!Correspondence_Fulfilment__c.Name}" />
    <apex:form >
         <script>        
            function SetTabTitleCorrespondence() {
                sforce.console.getEnclosingTabId(function(result) {
                   sforce.console.setTabTitle('CF-'+'{!Correspondence_Fulfilment__c.Name}', result.id);
                   sforce.console.setTabLink();
                   
                });
            }
            
            var pageLoad = window.onload;
            window.onload = function() {
                if (pageLoad) {
                        pageLoad();
                }
                SetTabTitleCorrespondence();
            }   
        </script>   
        <apex:pageBlock mode="detail">
            <!--<apex:pageBlockButtons id="btn">
                <apex:commandButton value="Edit" action="{!edit}"/>
            </apex:pageBlockButtons>-->
            <apex:pageBlockSection >
                <apex:outputField value="{!Correspondence_Fulfilment__c.LetterDesc__c}"/>
                <apex:outputField value="{!Correspondence_Fulfilment__c.LetterDate__c}"/>
                <apex:outputField value="{!Correspondence_Fulfilment__c.BrandDesc__c}" rendered="{!if(Correspondence_Fulfilment__c.BrandDesc__c == '', false, true)}"/>
                <apex:outputField value="{!Correspondence_Fulfilment__c.MasterId__c}" rendered="{!if(Correspondence_Fulfilment__c.MasterId__c == '', false, true)}"/>
                <apex:outputText value="" rendered="{!if(Correspondence_Fulfilment__c.MasterId__c == '', true, false)}"/>
            </apex:pageBlockSection>
            <apex:pageBlockSection columns="1" >
                <apex:outputField value="{!Correspondence_Fulfilment__c.Comments__c}"/>
            </apex:pageBlockSection>
        </apex:pageBlock>
    </apex:form>
</apex:page>