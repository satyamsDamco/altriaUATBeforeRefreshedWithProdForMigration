<apex:page StandardController="Case" extensions="IssueDetailController" sidebar="false" id="pg">
    <apex:includeScript value="/support/console/37.0/integration.js" /> 
    <apex:form id="frm"> 
        <apex:sectionHeader title="Issue Detail" subtitle="{!case.CaseNumber__c}" />   
        
        
        <script>   
        
        
        function SetTabIssueDetailTitle() {
            sforce.console.getEnclosingTabId(function(result) {
                sforce.console.setTabTitle('I-'+'{!case.CaseNumber__c}', result.id);
                sforce.console.setTabLink();
                
            });
        }
        function surveyApplicable(){
            var isSurveyApplicable = '{!isSurveyApplicable}';
            var tranCurrent = "{!currentTran}";
            if(isSurveyApplicable == 'Required' && tranCurrent != null && tranCurrent != ''){
                if("{!customerRecType}" == 'consumer'){
                    alert('Consumer eligible for survey');
                }else{
                    alert('Trade Customer eligible for survey');
                }
            }
        }            
        var pageLoad = window.onload;
        
        window.onload = function() {
            if (pageLoad) {
                pageLoad();
            }
            
            SetTabIssueDetailTitle();
            surveyApplicable();
            
        } 
        
        function reimbursement(){
            if('{!custId}' == null || '{!custId}' == ''){
                alert('Please create Consumer record before Reimbursement.');    
            }else if('{!customertype}' != 'CONSUMER'){
                alert('Cannot create reimbursement for Non-Consumer type Customer.');
            }else if('{!country}' != 'United States'){
                alert('Cannot create reimbursement for International Consumer.');
            }else if('{!case.Issue_Type__c}' != null && '{!case.Issue_Type__c}' != 'Complaints'){
                alert('Reimbursements only allowed for complaint issues');
            }else if('{!isReimbursed}' == 'true'){
                alert('Reimbursement already created');
            }/*else if('{!isAgeVerified}' == 'false'){
                    alert('Cannot create reimbursement. Consumer age is not verified.');
                }*/else{
                    sforce.console.getEnclosingPrimaryTabId(openSubtabReimb);   
                }
        }
        
        var openSubtabReimb = function openSubtabReimbursement(result) {
            var primaryTabId = result.id;            
            var issueId= '{!$CurrentPage.parameters.id}';           
            sforce.console.openSubtab(primaryTabId ,'/apex/ReimbursementEdit?issueId='+issueId, true, 'Reimbursement',null,  openSuccess, 'Reimbursement'+issueId);
        };
        
        function openSurvey(){
            sforce.console.getEnclosingPrimaryTabId(openSubtabSurvey);
        }
        
        var openSubtabSurvey = function openSubtabSurveyFun(result) {
            var primaryTabId = result.id;            
            var issueId= '{!$CurrentPage.parameters.id}';
            sforce.console.openSubtab(primaryTabId ,'/apex/IssueSurvey?issueId='+issueId, true, 'Survey',null,  openSuccess, 'Survey'+issueId);
        };
        
        function openAttachment(){
            sforce.console.getEnclosingPrimaryTabId(openSubtabAttachment);
        }
        
        var openSubtabAttachment = function openSubtabAttachmentFun(result) {
            var primaryTabId = result.id;            
            var issueId= '{!$CurrentPage.parameters.id}';
            sforce.console.openSubtab(primaryTabId ,'/apex/AttachmentUploadPage?issueId='+issueId, true, 'Attachment',null,  openSuccess, 'Attachment'+issueId);
        };   
        
        
        var attachmentId;
        var attachmentName;
        function attchmentDetail(id,Name){
            attachmentName = Name;
            attachmentId =  id;
            openAttachmentData();                          
        }
        
        
        function openAttachmentData(){            
            sforce.console.getEnclosingPrimaryTabId(openSubtabCustomer);        
        }
        var openSubtabCustomer = function openSubtab(result) {
            if(result.id !=null && result.id != 'null')
                sforce.console.openSubtab(result.id, '/apex/AttachmentDetailPage?id='+attachmentId , true, attachmentName, null, openSuccess, attachmentName+attachmentId);
            else
                sforce.console.openSubtab(null, '/apex/AttachmentDetailPage?id='+attachmentId, true, attachmentName, null, openSuccess, attachmentName+attachmentId);
        }
        
        
        
        function newStore(){
            sforce.console.getEnclosingPrimaryTabId(openSubtabStore);          
        } 
        
        var openSubtabStore = function openSubtabStore(result) {
            var primaryTabId = result.id;            
            var issueId= '{!$CurrentPage.parameters.id}';  
            var store = document.getElementById("{!$Component.frm:storeNum}").value;
            var pageNumber = 0;
            if(store == null || store == 'null'){
                pageNumber = 1;
                document.getElementById("{!$Component.frm:storeNum}").value = 1;
            }else{
                pageNumber = store;
                document.getElementById("{!$Component.frm:storeNum}").value = store +1;
            } 
            
            sforce.console.openSubtab(primaryTabId ,'/apex/StoreEditPage?pageNumber='+pageNumber+'&IssueId='+issueId, true, 'Store',null,  openSuccess, 'Store'+pageNumber);
        };            
        
        function newEmail()
        {
            sforce.console.getEnclosingPrimaryTabId(openSubtabEmail);
        }
        //----------------------------------
        var openSubtabEmail = function openSubtabStore(result) 
        {
            var primaryTabId = result.id;            
            var issueId= '{!$CurrentPage.parameters.id}';    
            var ContactId = '{!case.contactid}';            
            
            sforce.console.openSubtab(primaryTabId ,'/_ui/core/email/author/EmailAuthor?p3_lkid=' + issueId + '&p2_lkid=' + ContactId + '&p26=crc@altriacrc.com:CRC Support&p6=Photos for Altria Consumer Response Center#', true, 'Email', null,  null, 'Email Sub-tab');
            //primaryTabId:String 
            //url:URL
            //active:Boolean
            //tabLabel:String
            //id:String
            //(optional)callback:Function
            //(optional)name:String)
        };
        //------------------------------------------
        
        function openPrimaryTabEndCall(){             
            var custId = '{!custId}';
            var isSurveyApplicable = '{!isSurveyApplicable}';
            
            if(isSurveyApplicable == 'Required'){
                
                if(custId == null || custId == ''){
                    if("{!customerRecType}" == 'consumer'){
                        alert('Please present the survey or select a Cancel Reason \nPlease select the Consumer for which the issue is created');
                    }else{
                        alert('Please present the survey or select a Cancel Reason \nPlease select the Trade Customer for which the issue is created');
                    }
                }else{
                    alert('Please present the survey or select a Cancel Reason');                 
                }
            }else{
                if(custId == null || custId == ''){
                    if("{!customerRecType}" == 'consumer'){
                        alert('Please select the consumer for which the issue is created');
                    }else{
                        alert('Please select the trade customer for which the issue is created');
                    }
                }else{
                    sforce.console.getEnclosingPrimaryTabId(openSubtabEndCall); 
                }
            }                  
        }
        
        var openSubtabEndCall = function openSubtab(result) {
            var primaryTabId = result.id;
            sforce.console.openSubtab(primaryTabId,'/apex/EndCall' , true, 'End Call', null, openSuccess,'EndCall' );          
        }
        
        function openConsumer(eve) {
            if(eve == 'Contact'){
                sforce.console.getEnclosingPrimaryTabId(openSubtabConsumerDetail);
            }else{
                sforce.console.getEnclosingPrimaryTabId(openSubtabConsumerSearch);
            }
        }
        
        var openSubtabConsumerSearch = function openSubtab(result) {
            //Now that we have the primary tab ID, we can open a new subtab in it
            var primaryTabId = result.id;
            var parameters =  "{!parameters}";
            //alert(parameters );
            if("{!customerRecType}" == 'consumer'){
                sforce.console.openSubtab(primaryTabId , '/apex/ConsumerSearch?hideIssue=true'+parameters , true, 'Consumer Search', null,  openSuccess, 'Consumer Search');
            }else{
                sforce.console.openSubtab(primaryTabId , '/apex/TradeSearch?hideIssue=true'+parameters , true, 'Trade Customer Search', null,  openSuccess, 'Trade Customer Search');
            }
        };
        
        var openSubtabConsumerDetail = function openSubtab1(result) {
            //Now that we have the primary tab ID, we can open a new subtab in it
            var primaryTabId = result.id;
            var CustomerId = '{!case.contactid}'; 
            var CustomerName = '{!custName}';
            if("{!customerRecType}" == 'consumer'){
                sforce.console.focusSubtabByNameAndPrimaryTabId('Consumer', primaryTabId, openSuccess);
            }else{
                sforce.console.focusSubtabByNameAndPrimaryTabId('Trade', primaryTabId, openSuccess);
            }
            //sforce.console.openSubtab(primaryTabId , '/apex/ConsumerDetailPage?id='+CustomerId, true, CustomerName, null,  openSuccess, CustomerName+CustomerId);
        };
        
        
        var subTabIssue = '';
        function currentTabRefresh() {
            //First find the ID of the current tab to refresh it
            sforce.console.getEnclosingTabId(refreshCurrentTab);
        }
        var refreshCurrentTab = function refreshSubtab(result){
            var subTabId = result.id;               
            if(subTabIssue == subTabId || subTabIssue == ''){              
                subTabIssue  = '';                        
                ConsumerDetail();  
            }          
        }
        
        var openSuccess = function openSuccess(result) {
            //Report whether we succeeded in opening the subtab
            if (result.success == true) {
                //alert('subtab successfully opened');
            } else {
                //alert('subtab cannot be opened');
            }
        };
        
        var onFocusedSubtabCallback = function (result) {
            var entityId = result.objectId; 
            subTabIssue = result.id;
            document.getElementById("{!$Component.frm:pb:pbButton:refresh}").click();                          
        };  
        
        sforce.console.onFocusedSubtab(onFocusedSubtabCallback);
        
        function OpenSubtabSurvey() {
            //First find the ID of the primary tab to put the new subtab in
            sforce.console.getEnclosingPrimaryTabId(openSurveySubtab);
        }
        
        var openSurveySubtab = function openSurveySubtab(result) {
            //Now that we have the primary tab ID, we can open a new subtab in it
            var primaryTabId = result.id;
            var issueid= '{!$CurrentPage.parameters.id}';
            
            sforce.console.openSubtab(primaryTabId , '/apex/IssueSurveyList?pageSize=100&id='+issueid, true, 
                                      'Survey List', null, openSuccess, 'Survey List');
        };
        
        
        function openClonePage(){
            sforce.console.getEnclosingPrimaryTabId(opencloneSubtab);
        }            
        
        var opencloneSubtab = function opencloneSubtab(result) {
            //Now that we have the primary tab ID, we can open a new subtab in it
            var primaryTabId = result.id;
            var issueid= '{!$CurrentPage.parameters.id}';
            var issueNumber = '{!caseObj.CaseNumber__c}';
            var parameters =  "{!parameters}";
            sforce.console.openSubtab(primaryTabId , '/apex/IssueEntryClone?id='+issueid+'&parentIssue='+issueid+parameters, true, 
                                      'Clone Issue -'+issueNumber, null, openSuccess, 'Clone Issue -'+issueNumber);
        };
        
        
        function confirmsend()
        	{
				

                return confirm('Online Verification Form is about to be sent to the Consumer to verify their age. Do you want to proceed?');
			}
        
        </script>
        <style>
            .NewSurvey {
            background-color: #004A7F;
            -webkit-border-radius: 10px;
            border-radius: 10px;
            border: none;
            color: #FFFFFF;
            cursor: pointer;
            display: inline-block;
            font-family: Arial;
            font-size: 20px;
            padding: 5px 10px;
            text-align: center;
            text-decoration: none;
            }
            @-webkit-keyframes glowing {
            0% { background-color: #B20000; -webkit-box-shadow: 0 0 3px #B20000; }
            50% { background-color: #FF0000; -webkit-box-shadow: 0 0 40px #FF0000; }
            100% { background-color: #B20000; -webkit-box-shadow: 0 0 3px #B20000; }
            }
            
            @-moz-keyframes glowing {
            0% { background-color: #B20000; -moz-box-shadow: 0 0 3px #B20000; }
            50% { background-color: #FF0000; -moz-box-shadow: 0 0 40px #FF0000; }
            100% { background-color: #B20000; -moz-box-shadow: 0 0 3px #B20000; }
            }
            
            @-o-keyframes glowing {
            0% { background-color: #B20000; box-shadow: 0 0 3px #B20000; }
            50% { background-color: #FF0000; box-shadow: 0 0 40px #FF0000; }
            100% { background-color: #B20000; box-shadow: 0 0 3px #B20000; }
            }
            
            @keyframes glowing {
            0% { background-color: #B20000; box-shadow: 0 0 3px #B20000; }
            50% { background-color: #FF0000; box-shadow: 0 0 40px #FF0000; }
            100% { background-color: #B20000; box-shadow: 0 0 3px #B20000; }
            }
            
            .NewSurvey{
            -webkit-animation: glowing 1500ms infinite;
            -moz-animation: glowing 1500ms infinite;
            -o-animation: glowing 1500ms infinite;
            animation: glowing 1500ms infinite;
            }
        </style>
        <apex:inputHidden id="storeNum" />
        <apex:pageblock title="Issue Details" mode="detail"  id="pb">
            
                    <apex:pagemessages id="message"> 
                    </apex:pagemessages>                     
                                
            <apex:actionFunction name="ConsumerDetail" action="{!ConsumerDetails}" />
            <apex:pageBlockButtons id="pbButton">
                <apex:commandButton action="{!edit}" value="Edit" rendered="{!currentTran != null}"/>
                <apex:commandButton value="Reimbursement" onclick="reimbursement();return false;" rendered="{!If(customerRecType == 'consumer' && currentTran != null && country == $Label.Country,true,false)}"/>
                <!-- 10/30/19 JD: RITM0052177 - SCR 19-10-18 Stores - Allow Only 1 Per Issue ver 1.0 -->
                <apex:commandButton value="New Store" onclick="newStore();return false" rendered="{!currentTran != null}" disabled="{!isStoreEmpty}" /> 
                <!-- 10/30/19 JD: RITM0052177 -->
                <apex:commandButton value="Clone" action="{!customClone}" onclick="openClonePage();return false"  rendered="{!currentTran != null}"/>
                <apex:commandButton value="{!If(custId == '',(if(customerRecType == 'consumer','New Consumer','New Trade Customer')),(if(customerRecType == 'consumer','Consumer','Trade Customer')))}" onclick="openConsumer('{!If(custId == '', 'No Contact','Contact')}');return false"  rendered="{!currentTran != null}"/>
                <apex:commandButton value="Update Survey" onclick="openSurvey();return false" rendered="{!If(isSurveyApplicable != null && isSurveyApplicable != '' && isSurveyApplicable != 'Required' && isSurveyApplicable != 'Not Applicable' && currentTran != null,true,false)}"/>
                <apex:commandButton value="Survey" styleClass="NewSurvey" id="surveyNew" style="" onclick="openSurvey();return false" rendered="{!If(isSurveyApplicable == 'Required' && currentTran != null ,true,false)}"/>
                <apex:commandButton value="Attach File" onclick="openAttachment(); return false"  rendered="{!currentTran != null}"/>
                <apex:commandButton value="Online VF"  id="btnonlinevf" action="{!submitVF}" onclick="if (!confirmsend()) return false;" rendered="{!case.Contact.Email != null}"/>
                <apex:commandButton value="Refresh" onclick="currentTabRefresh(); return false" id="refresh"  rendered="{!currentTran != null}"/>
                <apex:commandButton value="End call"  onclick="openPrimaryTabEndCall();return false" id="btnEnd" rendered="{!currentTran != null}"/>
                <apex:commandButton value="Resend Survey" action="{!ResendSurvey}" id="btnResend" rendered="{!if(caseObj.IsReviewed__c == true && hasSurvey,true,false)}"/>
                
            </apex:pageBlockButtons>
            <apex:pageBlockSection title="Customer" id="customersec">
                <apex:pageBlockSectionItem >
                    <apex:outputLabel value="Customer ID"/>
                    <apex:outputText value="{!custId}"/>    
                </apex:pageBlockSectionItem>
                <apex:pageBlockSectionItem >
                    <apex:outputLabel value="Master ID"/>
                    <apex:outputText value="{!masterId}"/> 
                </apex:pageBlockSectionItem>
                <apex:pageBlockSectionItem >
                    <apex:outputText />  
                </apex:pageBlockSectionItem>
                <apex:pageBlockSectionItem >
                    <apex:outputLabel value="Name"/>
                    <apex:outputText value="{!custName}"/>  
                </apex:pageBlockSectionItem>
            </apex:pageBlockSection>
            <apex:pageBlockSection title="Product">
                <apex:outputField value="{!case.Product_Line__c}" label="Product Line"/>
                <apex:outputField value="{!case.Channel_Contact__c}"/>
            </apex:pageBlockSection>
            <apex:pageBlockSection title="Issue Hierarchy">
                <apex:outputField value="{!case.Classificationtxt__c}" label="Classification"/>
                <apex:outputField value="{!case.Reasontxt__c}" label="Reason"/>
