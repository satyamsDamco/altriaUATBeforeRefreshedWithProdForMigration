                <apex:inputField value="{!contact.DBA_Name__c}" styleClass="text-uppercase"  style="border-left:3px solid #c00" id="DBA" rendered="{!contact.CustomerType__c  ==$Label.Wholesaler ||contact.CustomerType__c  ==$Label.Retailer}" />
