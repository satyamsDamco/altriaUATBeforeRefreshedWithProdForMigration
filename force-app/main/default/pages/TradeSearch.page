                        <apex:outputText >Research Location</apex:outputText>
                        <apex:inputText value="{!conObj.Research_Location__c}" id="r5" styleClass="text-uppercase"/>
                        <apex:outputText >Research Panelist ID</apex:outputText>
                        <apex:inputText value="{!conObj.Research_Panelist_ID__c}" id="r6" styleClass="text-uppercase"/>
                        <apex:outputText >Project Flavor/Type</apex:outputText>
                        <apex:inputText value="{!conObj.Project_Flavor_Type__c}" id="r7" styleClass="text-uppercase"/>
                        <apex:outputText >Name</apex:outputText>
                        <apex:inputText value="{!conObj.Research_Panelist_Name__c}" id="r8" styleClass="text-uppercase"/>
                        <apex:outputText >Issue #</apex:outputText>
                        <apex:inputText value="{!issueid}" id="r9"/>
                        
                        
                        <apex:outputLabel ></apex:outputLabel>
                        <apex:outputLabel ></apex:outputLabel>
                        <apex:outputLabel ></apex:outputLabel>
                        <apex:outputLabel ><br/><br/><br/></apex:outputLabel>
                        
                     </apex:panelGrid> 
                </apex:outputPanel>
                     
                </apex:pageBlockSection>
           </apex:pageBlock>        
            <apex:pageBlock title="Search Result"  id="pb2"  rendered="{!If(conlst.size>0,true,false)}">
            <apex:pageBlockTable value="{!conlst}" var="c" id="pbt1">
                <apex:column headerValue="Local Records">
                    <input type="radio" name="chosen" onClick="return openCustomer('{!c.id}','{!c.Name}');"/>
                </apex:column>
                <apex:column headerValue="Customer ID">
                         <apex:OutputText value="{!c.CustomerID__c}"  label="CustomerID"/>
                </apex:column>
                <apex:column headerValue="Customer Type" rendered="{!selectedCustomerType == null || selectedCustomerType  == ''}">
                    <apex:OutputText value="{!c.CustomerType__c}" />
                </apex:column>
                <apex:column headerValue="{!If(selectedCustomerType == $Label.Field_Sales_Force,'FSF Agent Name','Company Name')}" rendered="{!selectedCustomerType != $Label.Research_Panelist}">
                    <apex:OutputText value="{!c.Company_Name__c}" />
                </apex:column>
                <apex:column headerValue="DBA Name" rendered="{!If((selectedCustomerType == $Label.Field_Sales_Force || selectedCustomerType == $Label.Research_Panelist),false,true)}">
                         <apex:OutputText value="{!c.DBA_Name__c}" />
                  </apex:column>
                   <apex:column headerValue="Account #" rendered="{!selectedCustomerType == $Label.Wholesaler}">
                         <apex:OutputText value="{!c.Account_No__c}" />
                  </apex:column>
                  <apex:column headerValue="Retail Control" rendered="{!selectedCustomerType == $Label.Retailer}">
                         <apex:OutputText value="{!c.Retail_control__c}" />
                  </apex:column>
                  <apex:column headerValue="{!if(selectedCustomerType == $Label.Field_Sales_Force,'FSF Phone','Phone')}" rendered="{!selectedCustomerType != $Label.Research_Panelist}">
                         <apex:OutputText value="{!c.Phone}" />
                  </apex:column>
                  <apex:column headerValue="FSF Email" rendered="{!selectedCustomerType == $Label.Field_Sales_Force}">
                         <apex:OutputText value="{!c.Email}" />
                  </apex:column>
                  <apex:column headerValue="FSF Territory" rendered="{!selectedCustomerType == $Label.Field_Sales_Force}">
                         <apex:OutputText value="{!c.Territory__c}" />
                  </apex:column>
                  <apex:column headerValue="Zip" rendered="{!selectedCustomerType != $Label.Field_Sales_Force && selectedCustomerType != $Label.Research_Panelist}">
                          <apex:OutputText value="{!c.Zip_Code__c}"/>
                  </apex:column>
                  
                  <!-- Research Panelist -->
                  <apex:column headerValue="Study Id" rendered="{!selectedCustomerType == $Label.Research_Panelist}">
                          <apex:OutputText value="{!c.Study_ID__c}"/>
                  </apex:column>
                  
                  <apex:column headerValue="Participant Id" rendered="{!selectedCustomerType == $Label.Research_Panelist}">
                          <apex:OutputText value="{!c.Participant_ID__c}"/>
                  </apex:column>
                  
                  <apex:column headerValue="Research Company" rendered="{!selectedCustomerType == $Label.Research_Panelist}">
                          <apex:OutputText value="{!c.Research_Company__c}"/>
                  </apex:column>
                  
                  <apex:column headerValue="Name" rendered="{!selectedCustomerType == $Label.Research_Panelist}">
                          <apex:OutputText value="{!c.Research_Panelist_Name__c}"/>
                  </apex:column>
                    
           </apex:pageBlockTable>           
        </apex:pageblock>
    </apex:form>
</apex:page>