            <apex:outputField value="{!contact.Research_Location__c}" id="resLoc" label="Research Location" rendered="{!contact.CustomerType__c == $Label.Research_Panelist}"/>
            
            <apex:outputField value="{!contact.Salutation}" id="prefix" label="Prefix" rendered="{!contact.CustomerType__c == $Label.Research_Panelist}" />
            
            <apex:outputField value="{!contact.Research_Panelist_Name__c}" id="rname" label="Name" rendered="{!contact.CustomerType__c == $Label.Research_Panelist}"/>
            
            <apex:outputField value="{!contact.Research_Panelist_Address__c}" id="rAdd" label="Address" rendered="{!contact.CustomerType__c == $Label.Research_Panelist}"/>
            
           </apex:pageBlockSection>
         
          <apex:pageBlockSection title="Other Information">
            <apex:outputField value="{!contact.Direct_Purchase__c}" rendered="{!contact.CustomerType__c == $Label.Wholesaler}"/>
            <apex:outputField value="{!contact.Store__c}"  rendered="{!contact.CustomerType__c ==$Label.Wholesaler}"/>
            <apex:outputField value="{!contact.Territory__c}" rendered="{!contact.CustomerType__c  ==$Label.Field_Sales_Force}"/>
            <apex:outputField value="{!contact.Hours_of_operation__c}" rendered="{!contact.CustomerType__c ==$Label.Wholesaler||contact.CustomerType__c   ==$Label.Retailer}"/>
            <apex:outputField value="{!contact.ALSD_Rep__c}" rendered="{!contact.CustomerType__c   ==$Label.Wholesaler||contact.CustomerType__c    ==$Label.Retailer}"/>
            
             <!-- Reseach Panelist Section -->
            <apex:outputField value="{!contact.Participation_Date__c}" id="partDate" label="Participation Date" rendered="{!contact.CustomerType__c == $Label.Research_Panelist}"/>
            
            <apex:outputField value="{!contact.Project_Flavor_Type__c}" id="proFlaType" label="Project Flavor/Type" rendered="{!contact.CustomerType__c == $Label.Research_Panelist}"/>
            
            <apex:outputField value="{!contact.Customer_Has_Product__c}" id="custHasProd" label="Customer Has Product" rendered="{!contact.CustomerType__c == $Label.Research_Panelist}"/>
            
            <apex:outputField value="{!contact.Research_Panelist_Notes__c}" id="resPanNotes" label="Customer Notes" rendered="{!contact.CustomerType__c == $Label.Research_Panelist}"/>
          </apex:pageBlockSection>  
        </apex:pageBlock>
        
       <apex:pageBlock >
           <apex:actionFunction name="test" rendered="true" action="subtabIssue();return false;"/>
       </apex:pageBlock>
       
       <apex:inputHidden id="refreshTag"/>
