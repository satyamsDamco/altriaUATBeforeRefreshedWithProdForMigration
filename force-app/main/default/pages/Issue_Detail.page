                <apex:outputField value="{!Case.Length_Code__c}" label="Length" rendered="{!IF(Case.Length_Code__c!='', true , false)}"/>
                <apex:outputField value="{!Case.Packaging__c}" label="Packaging" rendered="{!IF(Case.Packaging__c!='', true , false)}"/>
                <apex:outputField value="{!Case.Flavor__c}" label="Flavor" rendered="{!IF(Case.Flavor__c!='', true , false)}"/>
                <apex:outputField value="{!Case.Filter__c}" label="Filter" rendered="{!IF(Case.Filter__c!='', true , false)}"/>
                <apex:outputField value="{!Case.Paper_Type__c}" label="Paper Type" rendered="{!IF(Case.Paper_Type__c!='', true , false)}"/>
                <apex:outputLabel ></apex:outputLabel>
                <apex:outputField value="{!Case.Cut__c}" rendered="{!IF(Case.Cut__c!='', true , false)}"/>
            </apex:pageBlockSection>
            <!-- ================ IQOS Section ====================== -->
            <!-- <apex:pageBlockSection title="IQOS Information" id="IqosInfo" rendered="{!If(selectedProductLine =='HEAT NOT BURN',true,false)}"> -->
