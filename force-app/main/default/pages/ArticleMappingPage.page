         }
         
         html .calendarTable, body .calendarTable
         {
             font-size: 11px !important;
         }
         /*    fieldset
        {
            margin: 1em 0px;
            padding: 1em;
            border: 1px solid #ccc;
        }
    */
         fieldset.register label
