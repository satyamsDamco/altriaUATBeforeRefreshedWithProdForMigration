<apex:page StandardController="Case" extensions="IssueReviewDetailController" sidebar="false" id="pg" tabStyle="Issue_Review__tab">
    <apex:form id="frm"> 
        <script>
        window.onload = function() {
            var customerId = "{!custId}";
            if(customerId == null || customerId == ''){
                alert('The selected Issue does not have a Consumer/Customer associated to it and it cannot be approved.');
            }
        }
        </script>
        <apex:sectionHeader title="Issue Detail" subtitle="{!case.CaseNumber__c}" />
        <apex:outputLink value="/apex/IssueReview?sortDirection={!sortDir}&sortExpression={!sortExp}">«Back to Issue Review List</apex:outputLink>
        <apex:pageblock title="Issue Details" mode="detail"  id="pb">
            <apex:pageMessages id="message"/>
            <apex:pageBlockButtons id="pbButton">
                <apex:commandButton value="Review" action="{!setReview}" id="refresh" disabled="{!case.IsReviewed__c || (custId == null || custId == '')}"/>
            </apex:pageBlockButtons>
            <apex:pageBlockSection title="Customer" id="customersec">
                <apex:pageBlockSectionItem >
                    <apex:outputLabel value="Customer ID"/>
                    <apex:outputText value="{!custId}"/>    
                </apex:pageBlockSectionItem>
                <apex:pageBlockSectionItem > 
                    <apex:outputLabel value="Master ID"></apex:outputLabel>
                    <apex:outputText value="{!masterID}"/>
                </apex:pageBlockSectionItem>
                <apex:outputText />
                <apex:pageBlockSectionItem >
                    <apex:outputLabel value="Name"/>
                    <apex:outputText value="{!custName}"/>  
                </apex:pageBlockSectionItem>
            </apex:pageBlockSection>
            <apex:pageBlockSection title="Product">
                <apex:outputField value="{!case.Product_Line__c}" label="Product Line"/>
                <apex:outputField value="{!case.Channel_Contact__c}"/>
            </apex:pageBlockSection>
            <apex:pageBlockSection title="Issue Hierarchy">
                <apex:outputField value="{!case.Classificationtxt__c}" label="Classification"/>
                <apex:outputField value="{!case.Reasontxt__c}" label="Reason"/>
                <apex:outputField value="{!case.Issue_Type__c}" label="Issue Type"/>
                <apex:outputField value="{!case.Causetxt__c}" label="Cause"/>
                <apex:outputField value="{!case.Group_Code__c}" label="Group"/>
            </apex:pageBlockSection>
            
            <apex:pageBlockSection title="Brand Hierarchy" id="BrandHier">     
                <apex:outputField value="{!Case.UPC_code__c}" label="UPC" rendered="{!IF(Case.UPC_code__c!='', true , false)}"/>
                <apex:outputField value="{!Case.Packaging__c}" label="Packaging" rendered="{!IF(Case.Packaging__c!='', true , false)}"/>
                <apex:outputField value="{!Case.Brandcode__c}" label="Brand" rendered="{!IF(Case.Brandcode__c!='', true , false)}"/>
                <apex:outputField value="{!Case.Flavor__c}" label="Flavor" rendered="{!IF(Case.Flavor__c!='', true , false)}"/>
                <apex:outputField value="{!Case.Taste__c}" label="Taste" rendered="{!IF(Case.Taste__c!='', true , false)}"/>
                <apex:outputField value="{!Case.Filter__c}" label="Filter" rendered="{!IF(Case.Filter__c!='', true , false)}"/>
                <apex:outputField value="{!Case.Length_Code__c}" label="Length" rendered="{!IF(Case.Length_Code__c!='', true , false)}"/>
                <apex:outputField value="{!Case.Paper_Type__c}" label="Paper Type" rendered="{!IF(Case.Paper_Type__c!='', true , false)}"/>
                <apex:outputLabel ></apex:outputLabel>
                <apex:outputField value="{!Case.Cut__c}" rendered="{!IF(Case.Cut__c!='', true , false)}"/>
            </apex:pageBlockSection>
            
            <!-- ================ IQOS Section ====================== -->
            <!-- <apex:pageBlockSection title="IQOS Information" id="IqosInfo" rendered="{!If(selectedProductLine =='HEAT NOT BURN',true,false)}"> -->
            <apex:pageBlockSection title="IQOS Information" id="IqosInfo" rendered="{!iqosTrue}">
                <apex:outputField value="{!case.Serial_Number__c}" label="Serial Number" id="serialNumber"/>
                <apex:outputField value="{!case.IQOS_Reference_ID__c}" label="IQOS Reference ID" id="iqosRefId"/>
                <apex:outputField value="{!case.Original_Serial_Number__c}" label="Original Serial Number" id="origSerialNum"/>
                <apex:outputField value="{!case.Reimbursed_Or_Replaced_Indicator__c}" label="Reimbursed Or Replaced Indicator"  id="rOrIndicator"/> 
                <apex:outputField value="{!case.Third_Party_Reimbursement_Amount__c}" label="Third Party Reimbursement Amount" id="tprAmount"/>
                <apex:outputField value="{!case.Reimbursement_Amount__c}" label="Reimbursement Amount" id="rAmount"/>
                <apex:outputField value="{!case.CEA_Agent_ID__c}" label="CEA Agent ID" id="caID"/>
                <apex:outputField value="{!case.Complaint_Source__c}" label="Complaint Source" id="cSource"/>
                <apex:outputField value="{!case.Core_Service_API_Problem__c}" label="Core Service API Problem" id="csaProblem"/>
                <apex:outputField value="{!case.Warranty_Start_Date__c}" label="Warranty Start Date" id="wStartDate"/>
                <apex:outputField value="{!case.Warranty_Expiration_Date__c}" label="Warranty Expiration Date" id="wExDate"/>
                <apex:outputField value="{!case.Warranty_Status__c}" label="Warranty Status" id="wStatus"/>  
                <apex:outputField value="{!case.registrationDate__c}" label="Registration Date" id="regDate"/>   
                <apex:outputField value="{!case.registrationStatus__c}" label="Registration Status" id="regStatus"/> 
                <apex:outputField value="{!case.CCN__c}" label="CCN" id="ccn"/>  
            <!--    <apex:outputField value="{!case.Purchase_Date__c}" label="Purchase Date" id="purDate"/>  -->
                <apex:outputField value="{!case.Total_Paid_by_Customer__c}" label="Total Paid by Customer" id="tpCustomer"/> 
                <apex:outputField value="{!case.First_Time_Buyer__c}" label="First Time Buyer" id="ftBuyer"/>    
                <apex:outputField value="{!case.Base_Price__c}" label="Base Price" id="basePrice"/>                  
            </apex:pageBlockSection>
            <!-- ================ IQOS END ========================== -->    
            
            <apex:pageBlockSection title="Purchase Information" id="PurchaseInfo">
                <apex:outputField value="{!case.Purchase_Price__c}" label="Purchase Price" />
                <apex:outputField value="{!case.Affected_Type__c}" label="Affected Type" />
                <apex:outputField value="{!case.Purchase_Date__c}" label="Purchase Date"/>
                <apex:outputField value="{!case.AffectedQty__c}" label="Affected Quantity" />
                <apex:outputField value="{!case.Incident_Date__c}" label="Incident Date"/>
                <apex:outputField value="{!case.Expected_Type__c}" label="Expected Type"/>
                <apex:outputField value="{!case.Purchase_Type__c}" label="Purchase Type" />
                <apex:outputField value="{!case.ExpectedQty__c}" label="Expected Quantity" />
                <apex:outputField value="{!case.PurchaseQty__c}" label="Purchase Quantity" />
            </apex:pageBlockSection>
            
            <apex:pageBlockSection title="Issue Information " collapsible="TRUE" id="IssDetail" >
                <apex:outputField value="{!case.Trace_Code_Location__c}" label="Trace Code Location"/>
                <apex:outputField value="{!case.Suspected_Counterfiet__c}" label="Suspected Counterfeit"/>
                <apex:outputField value="{!case.Mfg_Trace_code__c}" label="Mfg/Trace code"/>
                <apex:outputtext rendered="{!iqosTrue}" />
                <apex:outputField value="{!case.TC_Serial_Number__c}" label="TC Serial Number" rendered="{!iqosTrue}"/> 
                <apex:outputField value="{!case.Suspected_Tampering__c}" label="Suspected Tampering"/> 
                
                <apex:outputText value="{0,date,MM/dd/yyyy}" label="Production Date"> 
                    <apex:param value="{!case.Production_date__c}" /> 
                </apex:outputText>  
               
                <apex:pageBlockSectionItem id="section1" rendered="{!IF(NOT(case.Product_Line__c=='Cigars' || case.Product_Line__c=='Green Smoke E-Vapor' || case.Product_Line__c=='E-Cigarette' || case.Product_Line__c =='MST'|| case.Product_Line__c =='Pouch'|| case.Product_Line__c =='Dry Snuff'|| case.Product_Line__c =='PMUSA Snus' || case.Product_Line__c =='USSTC Snus' ||case.Product_Line__c =='Loose Leaf' ),true, false)}"></apex:pageBlockSectionItem>
                <apex:outputField value="{!case.Date_Code__c}" id="datecode" rendered="{!case.Product_Line__c=='MST'||case.Product_Line__c=='Pouch'||case.Product_Line__c=='Dry Snuff'|| case.Product_Line__c=='PMUSA Snus'|| case.Product_Line__c=='USSTC Snus' ||case.Product_Line__c=='Loose Leaf' }"/>
                <apex:outputField value="{!case.Machine_Code__c}" id="machineCode" rendered="{!IF(case.Product_Line__c=='Cigars',true,false)}"/>
                <apex:outputField value="{!case.Exp_Date__c}" id="ExpDate"   rendered="{!IF(case.Product_Line__c=='Green Smoke E-Vapor',true,false)}"/>
                <apex:outputField value="{!case.DNUA_Date__c}" id="dnuaDate"  rendered="{!IF(case.Product_Line__c=='E-Cigarette',true,false)}"/>
                            
                <apex:outputField value="{!case.ProdrReturnReq__c}" label="Product Return Required for Reimbursement"/>
               
                <apex:pageBlockSectionItem id="section2" rendered="{!IF(NOT(case.Product_Line__c =='MST'|| case.Product_Line__c =='Pouch'|| case.Product_Line__c =='Dry Snuff'|| case.Product_Line__c =='PMUSA Snus'|| case.Product_Line__c =='USSTC Snus' ||case.Product_Line__c =='Loose Leaf' ),true, false)}">
                </apex:pageBlockSectionItem>
                <apex:outputText label="Date" value="{0,date,MM/dd/yyyy}" rendered="{!IF((case.Product_Line__c =='MST'|| case.Product_Line__c =='Pouch'|| case.Product_Line__c =='Dry Snuff'|| case.Product_Line__c =='PMUSA Snus'|| case.Product_Line__c =='USSTC Snus' ||case.Product_Line__c =='Loose Leaf' ),true, false)}">
                    <apex:param value="{!case.Date__c}" /> 
                </apex:outputText>
                <apex:outputField value="{!case.Outbound_Tracking__c}" label="Outbound Tracking #"/>
               
                <apex:pageBlockSectionItem id="section3" rendered="{!IF(NOT(case.Product_Line__c =='MST'|| case.Product_Line__c =='Pouch'|| case.Product_Line__c =='Dry Snuff'|| case.Product_Line__c =='PMUSA Snus' || case.Product_Line__c =='USSTC Snus' ||case.Product_Line__c =='Loose Leaf' ),true, false)}">
                </apex:pageBlockSectionItem>
                <apex:outputField value="{!case.Date_Type__c}" id="datetype" rendered="{!case.Product_Line__c=='MST'||case.Product_Line__c=='Pouch'||case.Product_Line__c=='Dry Snuff'|| case.Product_Line__c=='PMUSA Snus'|| case.Product_Line__c=='USSTC Snus' ||case.Product_Line__c=='Loose Leaf' }"/>
               
                <apex:outputField value="{!case.Inbound_Tracking__c}" label="Inbound Tracking #"/> 
               
                <apex:pageBlockSectionItem id="sell1" rendered="{!IF(NOT(case.Brandcode__c =='COPENHAGEN'),true,false)}"></apex:pageBlockSectionItem>
                
                <apex:outputField value="{!case.Update_Reason__c}" label="Update Reason" rendered="{!isUpdateReasonVisible}"/>
                
                <apex:outputField value="{!case.ThirdPartyContacted__c}" id="ThirdParty" rendered="{!If(case.Classificationtxt__c=='APE',true,false)}"/>
       
            </apex:pageBlockSection>
            
            <apex:pageBlockSection showHeader="false"> 
                <apex:outputField value="{!case.Consumer_Mentions__c}" label="Consumer Mentions"/>
                <apex:outputField value="{!case.Related_Issue__c}" label="Related Issue"/>
                <apex:outputPanel ></apex:outputPanel>     
            </apex:pageBlockSection>
            
            <apex:pageBlockSection showHeader="false"> 
                <apex:outputText value=" " label=" " />
                <apex:outputField value="{!case.NMI_Transaction_ID__c}" label="NMI Transaction ID"/>
                <apex:outputPanel ></apex:outputPanel>     
            </apex:pageBlockSection>
            
            <apex:pageBlockSection title="Trade Customer" id="TradeCustomer" rendered="{!If(customerRecType=='trade',true,false)}">
                <apex:outputField value="{!Case.Inventory_Depleted__c}" label="Depleted Inventory"/>
                <apex:outputField value="{!Case.Caller_Name__c}" label="Caller Name"/>
                <apex:outputField value="{!Case.Consumer_Return__c}" label="Consumer Return"/> 
                <apex:outputField value="{!Case.Supplier_Name__c}" label="Supplier Name"/>
                <apex:outputField value="{!Case.Comments__c}" label="Consumer Return Comments"/>
            </apex:pageBlockSection>            
                      
            <apex:pageBlockSection columns="1" title="Comment">
                <apex:outputField value="{!case.Comment__c}" style="width:100%"/>
            </apex:pageBlockSection>
            <apex:pageBlockSection columns="2" title="System Information">                
                <apex:outputField value="{!case.CreatedDate__c}" label="Created Date"/>                
                <apex:outputField value="{!case.LastModifiedDate__c}" label="Last Modified Date"/>
                <apex:outputField value="{!case.CreatedByName__c}" label="Created By"/>
                <apex:outputField value="{!case.LastModifiedByName__c}" label="Last Modified By"/>
                <apex:outputField value="{!case.IsReviewed__c}"/>
                <apex:outputField value="{!case.Survey__c}" rendered="false"/>
            </apex:pageBlockSection>            
            <apex:inputHidden id="reviewed" value="{!case.IsReviewed__c}"/>
        </apex:pageblock>        
    </apex:form>
     <apex:pageBlock title="Survey" id="surveyList">           
           <apex:outputPanel rendered="{!(IssueSurvyeList.size <=0)}">
               No records to display
           </apex:outputPanel>
           <apex:pageBlockTable value="{!IssueSurvyeList}" var="sn" rendered="{!(IssueSurvyeList.size >0)}">
               <apex:column headerValue="Survey Name">
                   &nbsp;&nbsp;<apex:OutputText value="{!sn.Survey_Name__c}"/>
               </apex:column>
               <apex:column headerValue="Question">
                    <apex:OutputText value="{!sn.QuestionText__c}"/>
               </apex:column>
               <apex:column headerValue="Answer">
                    <apex:OutputText value="{!sn.AnswerText__c }"/>
               </apex:column>               
               <apex:column headerValue="Comments">
                    <apex:OutputText value="{!sn.Comment__c}"/>
               </apex:column>            
           </apex:pageBlockTable>
           <br/>
           <apex:outputPanel rendered="{!(IssueSurvyeList.size >4)}">
               <apex:outputLink target="_blank" value="/apex/IssueSurveyList?fromPage=review&pageSize=100&id={!case.id}">View complete Survey List</apex:outputLink>
           </apex:outputPanel>
    </apex:pageBlock>
        <apex:relatedList list="stores__r" />
    	<apex:relatedList list="reimbursements__r"/>
</apex:page>