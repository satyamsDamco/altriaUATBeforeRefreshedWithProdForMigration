    <style type="text/css">
        .actionColumn {display:none; visibility:hidden}
    </style>
        <!-- Consumer Edit Screen start here --> 
        <apex:pageBlock rendered="{!Customershow && fromPage == null}" mode="Edit" id="pb">
        <apex:variable value="{!isNotEditable}" var="isNotEditableVar" />
        
        <apex:inputHidden id="str1" value="{!contact.Street_Address__c}"/>
        <apex:inputHidden id="str2" value="{!contact.Apt_Lot__c}"/>
        <apex:inputHidden id="str3" value="{!contact.Zip_Code__c}"/>

            <apex:actionFunction name="getCityData" action="{!getcitystate}" rerender="state,city,mg"/>
            <apex:actionFunction name="getCurrCountry" action="{!getCurrCountry}"/>
            <apex:actionFunction name="countryChanged" action="{!getCurrCountry}" oncomplete="blankCityState()"/>
             <apex:actionFunction action="{!CancelRedirect}" name="CancelRedirect"/>
            <apex:actionFunction name="streetChanged" action="{!streetChanged}" rerender="pbs1"/>
            <apex:actionfunction name="callSave" action="{!save}"/>
            
            <apex:pageMessages id="mg"></apex:pageMessages>
            <apex:pageBlockButtons id="pgBlckBtn">
                <apex:commandButton value="Assign Consumer" onclick="return assignContact()" action="{!assignContactTransaction}" rendered="{!If(fromPage != null && fromPage == 'search',true,false)}"/>
                <apex:commandButton value="Save" id="saveBtn" onclick="callSaveAction()" rendered="{!If(fromPage == null ,true,false)}" reRender="saveBtn,mg"/>
                <apex:commandButton value="Verify Address" id="addressButton" action="{!getaddressverified}" rendered="{!If(contact.Country__c == $Label.Country && fromPage == null,true,false)}"/>
                <apex:commandButton value="Cancel" onclick="CloseTabCustomer(); return false;"/>
            </apex:pageBlockButtons>
            
           <apex:pageBlockSection title="Consumer Information" id="pbs">       
                 <apex:selectList value="{!selectedCustomerTypeId}" id="f12" style="width:175px;" size="1" label="Customer Type">
                     <apex:selectOptions value="{!customerTypeList}"/>
                     <apex:actionSupport event="onchange" action="{!changeCustomerType}" rerender="pbs1,fm, ageVerifyId"/>
                 </apex:selectList>
              
                <apex:inputField value="{!contact.Salutation}" label="Prefix"/>
                <apex:inputField value="{!contact.FirstName}" required="false" id="f1" styleClass="text-uppercase"  style="border-left:3px solid #c00;"/>
                <apex:inputField value="{!contact.Suffix__c}"/>
                <apex:inputField value="{!contact.LastName}" styleClass="text-uppercase" required="false" id="f2" style="border-left:3px solid #c00"/>
                <apex:outputField value="{!contact.Repeat_Complainer__c}"  />
                <apex:inputcheckbox value="{!contact.DoNotUse__c}" disabled="{!isNotEditableVar}"/>
               <!--Edit Page-->
               <apex:inputcheckbox value="{!contact.ConsumerProductReturnRequired__c}" id="ProductReturnRequired1"  Label="Product Return Required" disabled="{!isNotEditableVar}"/>               
                
				

            </apex:pageBlockSection>
            
           <apex:pageBlockSection title="Address" id="pbs1" >
               
               <apex:inputField value="{!contact.Street_Address__c}" styleClass="text-uppercase"  style="border-left:3px solid #c00" id="add" onblur="resetAddressVerify(this);" onkeyup="resetAddressVerify(this);" onchange="changeToUppercase(this);streetChanged();" />
                <apex:inputText value="{!contact.City__c}" styleClass="text-uppercase" disabled="{!readOnlyCityState}" id="city"/>
               <apex:inputField value="{!contact.Apt_Lot__c}" styleClass="text-uppercase" id="apt" onblur="resetAddressVerify(this);"  onkeyup="resetAddressVerify(this);" onchange="changeToUppercase(this);streetChanged();"/>     
                <apex:inputText value="{!contact.State__c}" styleClass="text-uppercase" disabled="{!readOnlyCityState}" id="state" />
                <apex:inputField value="{!contact.Zip_Code__c}" required="false" onkeyup="zipValid(this.value);resetAddressVerify(this);"  styleClass="text-uppercase" onblur="resetAddressVerify(this);" onchange="changeToUppercase(this);getCityData();streetChanged();" id="zip" style="border-left:3px solid #c00"/>  
                <apex:inputField value="{!contact.Country__c}" id="country" >
                    <apex:actionSupport event="onchange" rerender="pbs1,fm" oncomplete="countryChanged();readableCityState();resetAddressVerify();streetChanged();"/>
                </apex:inputField>
                 <apex:outputField value="{!contact.Address_Verified__c}" id="chkAddress" rendered="{!If(contact.Country__c == $Label.Country,true,false)}"/>
                  <apex:inputField value="{!contact.Verify_Address__c}" id="chkAddress1" label="Consumer Verify Address" rendered="{!If(contact.Country__c == $Label.Country,true,false)}"/> 
                </apex:pageBlockSection>
               
                <apex:pageBlockSection title="Contact Information" id="pbs2">
                <apex:inputField value="{!contact.Phone}" label="Telephone"/>
                <apex:inputField value="{!contact.OtherPhone}" label="Alternate Telephone"/>
                <apex:inputField value="{!contact.MobilePhone}" label="Mobile Phone"/>
                <apex:outputLabel ></apex:outputLabel>
                <apex:pageBlockSectionItem id="em">
                    <apex:outputLabel value="Email Address" for="email" />
                    <apex:inputField value="{!contact.Email}" id="email" onchange="resetEmailVerification();"/> 
                </apex:pageBlockSectionItem>
                    <apex:inputField value="{!contact.Email_Verified__c}" label="Email Verified" id="chkEmail" onchange="chkEmail();"/>
            </apex:pageBlockSection> 
               
            <apex:outputPanel id="op3" >
                 <apex:pageBlockSection title="Birthdate" id="pbs3" rendered="{!contact.CustomerType__c==$Label.CustomerType}">
                    <apex:pageBlockSectionItem rendered="{!dobEditable}">
                        <apex:outputLabel value="Date Of Birth"/>   
                        <apex:inputField value="{!contact.Birthdate1__c}" onclick="updateCalYearPicker();" onchange="alertAgeVerify();"/>
                    </apex:pageBlockSectionItem>
                    <apex:pageBlockSectionItem rendered="{!NOT(dobEditable)}">
                        <apex:outputLabel value="Date Of Birth"/>
                        <apex:outputField value="{!contact.Birthdate1__c}"/>
                    </apex:pageBlockSectionItem>
                     <!--  <apex:inputField value="{!contact.Birthdate1__c}" label="Date Of Birth" onclick="updateCalYearPicker();"/>--> 
                   
                 </apex:pageBlockSection>
               
                 <apex:pageBlockSection title="Age Verification" id="pbs4" rendered="{!if(isAgeVerificationReq && contact.CustomerType__c==$Label.CustomerType, true, false)}">
                     <apex:inputField value="{!contact.AVF_GIID_Received__c}"/>
                     <apex:outputField value="{!contact.Age_Verification_Source__c}"/>
                 </apex:pageBlockSection>
             </apex:outputPanel>
        
        </apex:pageBlock>
        
