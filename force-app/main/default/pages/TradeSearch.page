             function SetTabTitleTrade() {
                sforce.console.getEnclosingTabId(function(result) {
                   sforce.console.setTabTitle('Trade Customer Search', result.id);
                });
            } 
             
             function getPrimaryTabId(){
				  document.cookie = 'apex__tranid={!tranid}; SameSite=None; Secure; path=/';
                  sforce.console.getEnclosingPrimaryTabId(DisableTabCloseTrueWithId);
             }
             var DisableTabCloseTrueWithId = function DisableTabCloseTrueWithId(result) {
                var primaryTabId = result.id;
                sforce.console.disableTabClose(false, primaryTabId);
             }  
            
           
            
        function openPrimaryTabTrade(val){
        
           if(val == 'No Contact'){ 
               sforce.console.getEnclosingPrimaryTabId(openSubtabTrade);
           }else{
           
                sforce.console.getEnclosingPrimaryTabId(function openSubtabTrade1(result) {
                    //Now that we have the primary tab ID, we can open a new subtab in it
                    var primaryTabId = result.id;
                    var CustomerId = val; 
                    
                    if(result.id != 'null' && result.id !=  null){
                         sforce.console.openSubtab(primaryTabId , '/apex/ConsumerDetailPage?id='+CustomerId, true, 'Trade'+CustomerId, null,  openSuccess, 'Trade');
                    }else{
                       sforce.console.openPrimaryTab(null, '/apex/ConsumerDetailPage?id='+CustomerId, true, 'Trade'+CustomerId, null,  openSuccess, 'Trade');
                    }
                });
            }    
        }
        
       
        
