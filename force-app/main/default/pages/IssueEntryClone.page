        function setFieldsValidation() {
            var control = $('[id$="purchaseQty"]');
            if (control != null) 
                control.numeric({ decimal: false, negative: false }, function() { alert("Positive Integers only"); this.value = ""; this.focus(); });            
            
            control = $('[id$="expectQty"]');
            if (control != null)
                control.numeric({ decimal: false, negative: false }, function() { alert("Positive Integers only"); this.value = ""; this.focus(); });
           
           control = $('[id$="affectQty"]');
