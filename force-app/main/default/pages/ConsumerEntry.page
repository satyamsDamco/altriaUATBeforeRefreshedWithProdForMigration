                <apex:inputField value="{!contact.Retail_control__c}"  id="Ret" rendered="{!contact.CustomerType__c ==$Label.Retailer}"/>
                <apex:inputField value="{!contact.Company_Name__c}" styleClass="text-uppercase"  style="border-left:3px solid #c00" id="compName" label="FSF Agent Name" rendered="{!contact.CustomerType__c   ==$Label.Field_Sales_Force}"/>
                
                <!-- Reseach Panelist Section -->
                <apex:inputText value="{!contact.Research_Panelist_ID__c}" id="respanID" label="Research Panelist ID" rendered="{!contact.CustomerType__c == $Label.Research_Panelist}" disabled="true" styleClass="text-uppercase"/>
                
                <apex:inputField label="Participant ID" value="{!contact.Participant_ID__c}" id="partID" rendered="{!contact.CustomerType__c == $Label.Research_Panelist}" styleClass="text-uppercase"/>
                
                <apex:inputField label="Study ID" value="{!contact.Study_ID__c}" id="studID" rendered="{!contact.CustomerType__c == $Label.Research_Panelist}"  styleClass="text-uppercase"  style="border-left:3px solid #c00" />
                
                <apex:inputField label="Blinding Code" value="{!contact.Blinding_Code__c}" id="billCode" rendered="{!contact.CustomerType__c == $Label.Research_Panelist}" styleClass="text-uppercase"/>
            </apex:pageBlockSection>
           
            
