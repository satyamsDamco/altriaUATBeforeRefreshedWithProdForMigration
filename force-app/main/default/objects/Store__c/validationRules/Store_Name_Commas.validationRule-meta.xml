<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Store_Name_Commas</fullName>
    <active>true</active>
    <errorConditionFormula>CONTAINS(    Store_Name__c   , &quot;,&quot;)</errorConditionFormula>
    <errorDisplayField>Store_Name__c</errorDisplayField>
    <errorMessage>Field Cannot contain commas</errorMessage>
</ValidationRule>
