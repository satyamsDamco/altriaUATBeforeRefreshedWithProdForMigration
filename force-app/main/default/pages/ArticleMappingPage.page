<apex:page id="page" standardController="Natural_Language__c" extensions="ArticleMappingController">
<apex:form id="form1">
    <apex:sectionHeader title="Article Mapping" />
    
    
    <script>
       
  
   function toggleEnableDisable(enableDisable){  	
        var allButtons = document.getElementsByTagName('input');   
        //alert(enableDisable);      
        for(var i=0;i<allButtons.length;i++){
            if(allButtons[i].id.indexOf('SvButton') > -1){                
                if(enableDisable){
                    allButtons[i].disabled = true;
                    allButtons[i].value = 'Saving';
                    allButtons[i].className = 'btnDisabled';
                    //alert(allButtons[i].id);
                }
                else{
                    allButtons[i].disabled = false;
                    allButtons[i].value = 'Save'};
                    allButtons[i].className = 'btn';
                }
           
            if(allButtons[i].id.indexOf('cancel') > -1){
                if(enableDisable){
                    allButtons[i].disabled = true;
                    allButtons[i].value = 'Saving';
                    allButtons[i].className = 'btnDisabled';
                }
                else{
                    allButtons[i].disabled = false;
                    allButtons[i].value = '.Cancel';
                    allButtons[i].className = 'btn';
                }
            }
        }
        }
    
    </script>  
    
    <style>
